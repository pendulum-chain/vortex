{
  "dependencies": {
    "@vortexfi/shared": "workspace:*"
  },
  "description": "Provider KYC/KYB state machines, shared by the widget and the dashboard",
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "catalog:",
    "xstate": "^5.20.1",
    "zod": "^4.3.6"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "name": "@vortexfi/kyc",
  "peerDependencies": {
    "xstate": "^5.20.1",
    "zod": "^4.3.6"
  },
  "private": true,
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov && bun ../../scripts/check-coverage.ts coverage/lcov.info 0.30 0.15",
    "typecheck": "tsc --noEmit",
    "verify": "biome check --no-errors-on-unmatched"
  },
  "type": "module",
  "types": "./src/index.ts",
  "version": "0.1.0"
}
