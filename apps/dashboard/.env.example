# Vortex API origin. Dev default (unset) is http://localhost:3000; production builds
# are served same-origin under /dashboard/, so set this only when that doesn't hold.
VITE_API_URL=http://localhost:3000

# Optional: used when presigning ephemeral EVM transactions via signUnsignedTransactions.
VITE_ALCHEMY_API_KEY=

# Widget origin used for recipient onboarding links. Dev default (unset) is
# http://127.0.0.1:5173; production builds fall back to the page origin. Set this only
# when the widget is not served on the same origin as the dashboard.
VITE_WIDGET_URL=
